@* Модальная форма добавления/редактирования работы (MudBlazor-диалог). *@
@inject DiplomaService Data
@inject AdminState Admin
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm Model="Item" OnValidSubmit="HandleSubmit" id="diploma-edit-form">
            <DataAnnotationsValidator />
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Item.Student" Label="Студент" Required="true"
                                  For="@(() => Item.Student)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="8" sm="4">
                    <MudTextField @bind-Value="Item.Group" Label="Группа"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudNumericField @bind-Value="Item.Year" Label="Год" For="@(() => Item.Year)"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.Topic" Label="Тема" Required="true" Lines="2"
                                  For="@(() => Item.Topic)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.Supervisor" Label="Руководитель"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.Description" Label="Краткое описание" Lines="4"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Item.RepoUrl" Label="Ссылка на исходный код"
                                  Placeholder="https://..." For="@(() => Item.RepoUrl)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Item.InstallUrl" Label="Ссылка на установочный файл"
                                  Placeholder="https://..." For="@(() => Item.InstallUrl)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Item.DemoUrl" Label="Ссылка на демонстрацию"
                                  Placeholder="https://..." For="@(() => Item.DemoUrl)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Variant="Variant.Filled">@_error</MudAlert>
            }
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Отмена</MudButton>
        <MudButton ButtonType="ButtonType.Submit" form="diploma-edit-form"
                   Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy">
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Сохранить
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public Diploma Item { get; set; } = default!;

    private string? _error;
    private bool _busy;

    private async Task HandleSubmit()
    {
        _busy = true;
        _error = null;
        try
        {
            await Data.SaveAsync(Item, Admin.Token!);
            Snackbar.Add("Работа сохранена", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Item));
        }
        catch (Exception ex)
        {
            _error = $"Не удалось сохранить: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
