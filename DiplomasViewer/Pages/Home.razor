@page "/"
@implements IDisposable
@inject DiplomaService Data
@inject AdminState Admin
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Дипломные работы</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">
    Дипломные работы студентов специальности «Информационные системы и технологии», ИТ ФАИС ГГТУ
</MudText>

@if (!string.IsNullOrEmpty(_pageError))
{
    <MudAlert Severity="Severity.Error" Class="mb-3" Variant="Variant.Filled">@_pageError</MudAlert>
}

<MudGrid Class="mb-3" Spacing="2">
    <MudItem xs="12" sm="6" md="4">
        <MudTextField @bind-Value="Search" Immediate="true" Label="Поиск"
                      Placeholder="студент, тема, руководитель…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudSelect @bind-Value="Group" Label="Группа" Clearable="true"
                   Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem Value="@("")">Все</MudSelectItem>
            @foreach (var g in Groups)
            {
                <MudSelectItem Value="@g">@g</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudSelect @bind-Value="Year" Label="Год" Clearable="true"
                   Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem Value="@("")">Все</MudSelectItem>
            @foreach (var y in Years)
            {
                <MudSelectItem Value="@y.ToString()">@y</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    @if (Admin.IsAdmin)
    {
        <MudItem xs="12" md="4" Class="d-flex align-center justify-md-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="AddNew">
                Добавить работу
            </MudButton>
        </MudItem>
    }
</MudGrid>

<MudTable Items="Filtered" Hover="true" Striped="true" Dense="true" Breakpoint="Breakpoint.Sm"
          Loading="@(!Data.Loaded)" LoadingProgressColor="Color.Primary" Elevation="1">
    <HeaderContent>
        <MudTh Style="width:1%"></MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="@(new Func<Diploma, object>(x => x.Student))"
                               InitialDirection="SortDirection.Ascending">Студент</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="@(new Func<Diploma, object>(x => x.Group))">Группа</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="@(new Func<Diploma, object>(x => x.Topic))">Тема</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="@(new Func<Diploma, object>(x => x.Supervisor))">Руководитель</MudTableSortLabel>
        </MudTh>
        <MudTh Style="text-align:center">
            <MudTableSortLabel SortBy="@(new Func<Diploma, object>(x => x.Year ?? 0))">Год</MudTableSortLabel>
        </MudTh>
        <MudTh Style="text-align:center">Ссылки</MudTh>
        @if (Admin.IsAdmin)
        {
            <MudTh Style="text-align:right">Действия</MudTh>
        }
    </HeaderContent>
    <RowTemplate>
        <MudTd Style="width:1%">
            @if (!string.IsNullOrWhiteSpace(context.Description))
            {
                <MudIconButton Size="Size.Small"
                               Icon="@(IsExpanded(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               OnClick="@(() => ToggleExpand(context.Id))" aria-label="Описание" />
            }
        </MudTd>
        <MudTd DataLabel="Студент">@context.Student</MudTd>
        <MudTd DataLabel="Группа">@context.Group</MudTd>
        <MudTd DataLabel="Тема">@context.Topic</MudTd>
        <MudTd DataLabel="Руководитель">@context.Supervisor</MudTd>
        <MudTd DataLabel="Год" Style="text-align:center">@context.Year</MudTd>
        <MudTd DataLabel="Ссылки" Style="text-align:center">
            <div class="d-flex flex-wrap gap-1 justify-center">
                @if (!string.IsNullOrWhiteSpace(context.RepoUrl))
                {
                    <MudChip T="string" Href="@context.RepoUrl" Target="_blank"
                             Icon="@Icons.Material.Filled.Code" Color="Color.Primary"
                             Variant="Variant.Text" Size="Size.Small">Исходный код</MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(context.InstallUrl))
                {
                    <MudChip T="string" Href="@context.InstallUrl" Target="_blank"
                             Icon="@Icons.Material.Filled.Download" Color="Color.Primary"
                             Variant="Variant.Text" Size="Size.Small">Установочный файл</MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(context.DemoUrl))
                {
                    <MudChip T="string" Href="@context.DemoUrl" Target="_blank"
                             Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary"
                             Variant="Variant.Text" Size="Size.Small">Демонстрация</MudChip>
                }
            </div>
        </MudTd>
        @if (Admin.IsAdmin)
        {
            <MudTd DataLabel="Действия" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                               Size="Size.Small" OnClick="@(() => Edit(context))" aria-label="Изменить" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               Size="Size.Small" OnClick="@(() => Delete(context))" aria-label="Удалить" />
            </MudTd>
        }
    </RowTemplate>
    <ChildRowContent>
        @if (IsExpanded(context.Id) && !string.IsNullOrWhiteSpace(context.Description))
        {
            <MudTr>
                <MudTd colspan="@(Admin.IsAdmin ? 8 : 7)" Class="mud-background-gray">
                    <MudText Typo="Typo.subtitle2">Краткое описание</MudText>
                    <MudText Typo="Typo.body2" Style="white-space:pre-wrap">@context.Description</MudText>
                </MudTd>
            </MudTr>
        }
    </ChildRowContent>
    <NoRecordsContent>
        <MudText Align="Align.Center" Class="py-4" Color="Color.Default">Ничего не найдено.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText Align="Align.Center" Class="py-4">Загрузка…</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }"
                       RowsPerPageString="Работ на странице"
                       InfoFormat="{first_item}–{last_item} из {all_items}" />
    </PagerContent>
</MudTable>

@code {
    private string _search = "";
    private string _group = "";
    private string _year = "";

    private string Search { get => _search; set => _search = value ?? ""; }
    private string Group { get => _group; set => _group = value ?? ""; }
    private string Year { get => _year; set => _year = value ?? ""; }

    private readonly HashSet<string> _expanded = new();
    private string? _pageError;

    protected override async Task OnInitializedAsync()
    {
        Data.OnChange += StateHasChanged;
        Admin.OnChange += ReloadOnAdminChange;
        await Admin.EnsureInitializedAsync();
        await Reload();
    }

    private async void ReloadOnAdminChange() => await Reload();

    private async Task Reload()
    {
        _pageError = null;
        try
        {
            await Data.LoadAsync(Admin);
        }
        catch (Exception ex)
        {
            _pageError = $"Не удалось загрузить данные: {ex.Message}";
        }
        StateHasChanged();
    }

    private IEnumerable<string> Groups =>
        Data.Items.Select(d => d.Group).Where(g => !string.IsNullOrWhiteSpace(g)).Distinct().OrderBy(g => g);

    private IEnumerable<int> Years =>
        Data.Items.Where(d => d.Year.HasValue).Select(d => d.Year!.Value).Distinct().OrderByDescending(y => y);

    private IEnumerable<Diploma> Filtered
    {
        get
        {
            var q = Data.Items.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_group))
                q = q.Where(d => d.Group == _group);
            if (!string.IsNullOrWhiteSpace(_year) && int.TryParse(_year, out var y))
                q = q.Where(d => d.Year == y);
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                q = q.Where(d =>
                    Contains(d.Student, s) || Contains(d.Topic, s) ||
                    Contains(d.Supervisor, s) || Contains(d.Description, s));
            }
            return q;
        }
    }

    private static bool Contains(string? value, string term) =>
        value is not null && value.Contains(term, StringComparison.CurrentCultureIgnoreCase);

    private bool IsExpanded(string id) => _expanded.Contains(id);

    private void ToggleExpand(string id)
    {
        if (!_expanded.Add(id)) _expanded.Remove(id);
    }

    private Task AddNew() =>
        ShowEditDialog(new Diploma { Year = Years.FirstOrDefault(DateTime.Now.Year) }, "Добавить работу");

    private Task Edit(Diploma d) => ShowEditDialog(d.Clone(), "Изменить работу");

    private async Task ShowEditDialog(Diploma model, string title)
    {
        var parameters = new DialogParameters<DiplomaEditDialog> { { x => x.Item, model } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<DiplomaEditDialog>(title, parameters, options);
    }

    private async Task Delete(Diploma d)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            "Удаление работы",
            $"Удалить работу студента «{d.Student}»?",
            yesText: "Удалить", cancelText: "Отмена");
        if (ok != true) return;

        try
        {
            await Data.DeleteAsync(d.Id, Admin.Token!);
            Snackbar.Add("Работа удалена", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Не удалось удалить: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        Data.OnChange -= StateHasChanged;
        Admin.OnChange -= ReloadOnAdminChange;
    }
}
